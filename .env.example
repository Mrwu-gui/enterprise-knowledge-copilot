# 推荐直接改 config/api_keys.txt
# 如果你更喜欢 .env，也可以在这里填多个 Key，用英文逗号分隔
# DASHSCOPE_API_KEYS=sk-your-key-1,sk-your-key-2,sk-your-key-3

# 可选：只填一个 Key 时也能用
# DASHSCOPE_API_KEY=sk-your-single-key

# 可选：模型与后台配置
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
LLM_MODEL_FALLBACK=qwen-plus
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请首次启动后自行设置
