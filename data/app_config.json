    "surface_strong": "#fffef8",
    "line": "#eadbb8",
    "text": "#4c3e2c",
    "muted": "#866f59",
    "accent": "#13b6ad",
    "accent_strong": "#0f9692",
    "accent_soft": "rgba(19, 182, 173, 0.14)",
    "warm": "#f3c067",
    "warm_soft": "rgba(243, 192, 103, 0.2)",
    "danger": "#d06b5a"
