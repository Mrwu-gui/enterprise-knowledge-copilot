      "desc": "高时效、随时变化的知识"
    },
    "seasonal": {
      "label": "L2 增量库",
      "weight": 2.0,
      "desc": "阶段性更新、偶尔变更的知识"
    },
    "permanent": {
      "label": "L1 基础库",
      "weight": 1.0,
      "desc": "长期稳定、基本不变的知识"
    }
  },
  "theme": {
    "bg": "#f6f1df",
