          }
        },
        {
          "id": "knowledge_1",
          "type": "knowledge",
          "x": 360,
          "y": 180,
          "data": {
            "label": "招聘规则检索",
            "description": "从岗位画像、面试标准与 offer 流程中检索相关内容",
            "query": "{{input.text}}",
            "knowledgeBase": "默认知识库",
            "topK": 5,
            "threshold": 0.16
          }
        },
        {
          "id": "condition_1",
          "type": "condition",
          "x": 660,
          "y": 180,
          "data": {
            "label": "判断是否命中招聘规则",
            "description": "命中则输出招聘建议，否则输出通用筛选建议",
            "condition": "len(last.hits) > 0"
          }
        },
        {
          "id": "ai_hit",
          "type": "ai",
          "x": 980,
          "y": 80,
          "data": {
            "label": "生成招聘建议",
            "description": "结合岗位与规则给出筛选、面试或沟通建议",
            "prompt": "你是智联招聘企业招聘中心的招聘助手。请基于用户问题和知识片段，输出结构化招聘建议。用户问题：{{input.text}}\n\n知识片段：{{last.knowledge_text}}\n\n要求：1. 先给结论；2. 如涉及候选人筛选，请列出优点、风险和建议；3. 如涉及流程，按步骤输出；4. 只输出最终答复。",
            "model": "__default__",
            "temperature": 0.3
          }
        },
        {
          "id": "ai_fallback",
          "type": "ai",
          "x": 980,
          "y": 300,
          "data": {
            "label": "生成筛选兜底",
            "description": "知识不足时给出通用招聘建议",
            "prompt": "你是智联招聘企业招聘中心的招聘助手。当前知识库未命中明确规则。请输出谨慎的通用招聘建议。用户问题：{{input.text}}\n\n要求：1. 明确说明未检索到企业内部明确规则；2. 可以给一般招聘建议；3. 不要虚构企业制度。",
            "model": "__default__",
            "temperature": 0.2
          }
        },
        {
          "id": "end_1",
          "type": "end",
          "x": 1290,
          "y": 190,
          "data": {
            "label": "结束节点",
            "description": "返回答复结果",
            "endType": "正常结束",
            "endMessage": "{{last.text}}"
          }
        }
