        },
        {
          "id": "knowledge_1",
          "type": "knowledge",
          "x": 360,
          "y": 180,
          "data": {
            "label": "客服规则检索",
            "description": "从中国电信套餐规则、故障口径与工单升级标准中检索相关内容",
            "query": "{{input.text}}",
            "knowledgeBase": "默认知识库",
            "topK": 5,
            "threshold": 0.16
          }
        },
        {
          "id": "condition_1",
          "type": "condition",
          "x": 660,
          "y": 180,
          "data": {
            "label": "判断是否命中客服规则",
            "description": "命中则输出标准答复，否则输出谨慎兜底答复",
            "condition": "len(last.hits) > 0"
          }
        },
        {
          "id": "ai_hit",
          "type": "ai",
          "x": 980,
          "y": 80,
          "data": {
            "label": "生成客服答复",
            "description": "结合规则输出标准客服话术和处理建议",
            "prompt": "你是中国电信客户服务中心的客服助手。请根据用户问题和企业知识片段，输出标准客服答复。用户问题：{{input.text}}\n\n知识片段：{{last.knowledge_text}}\n\n要求：1. 先输出客服结论；2. 如需处理动作，按步骤说明；3. 如需升级工单，明确升级条件；4. 语言要像客服坐席可直接发送给用户。",
            "model": "__default__",
            "temperature": 0.3
          }
        },
        {
          "id": "ai_fallback",
          "type": "ai",
          "x": 980,
          "y": 300,
          "data": {
            "label": "生成服务兜底",
            "description": "知识不足时给出谨慎客服建议",
            "prompt": "你是中国电信客户服务中心的客服助手。当前知识库未命中明确规则。请给出谨慎客服答复。用户问题：{{input.text}}\n\n要求：1. 说明当前未检索到内部明确规则；2. 可以给一般客户服务建议；3. 不要虚构套餐或赔付承诺。",
            "model": "__default__",
            "temperature": 0.2
          }
        },
        {
          "id": "end_1",
          "type": "end",
          "x": 1290,
          "y": 190,
          "data": {
