            "query": "{{input.text}}",
            "knowledgeBase": "默认知识库",
            "topK": 5,
            "threshold": 0.16
          }
        },
        {
          "id": "condition_1",
          "type": "condition",
          "x": 660,
          "y": 180,
          "data": {
            "label": "判断是否命中培训知识",
            "description": "命中则输出学习建议，否则输出通用成长建议",
            "condition": "len(last.hits) > 0"
          }
        },
        {
          "id": "ai_hit",
          "type": "ai",
          "x": 980,
          "y": 80,
          "data": {
            "label": "生成学习建议",
            "description": "结合课程知识输出学习计划与答疑建议",
            "prompt": "你是新东方企业培训平台的学习教练。请根据用户问题和知识片段，输出清晰的学习辅导建议。用户问题：{{input.text}}\n\n知识片段：{{last.knowledge_text}}\n\n要求：1. 先给结论；2. 如涉及学习计划，按阶段列出；3. 如涉及课程规则，明确时间和要求；4. 只输出最终答复。",
            "model": "__default__",
            "temperature": 0.3
          }
        },
        {
          "id": "ai_fallback",
          "type": "ai",
          "x": 980,
          "y": 300,
          "data": {
            "label": "生成成长兜底",
            "description": "知识不足时给出通用学习建议",
            "prompt": "你是新东方企业培训平台的学习教练。当前知识库未命中明确规则。请输出谨慎的通用学习建议。用户问题：{{input.text}}\n\n要求：1. 说明当前未检索到平台内部明确规则；2. 可以给一般学习建议；3. 不要虚构课程制度。",
            "model": "__default__",
            "temperature": 0.2
          }
        },
        {
